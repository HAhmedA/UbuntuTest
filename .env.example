# Database
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=postgres

# Session
SESSION_SECRET=change-this-to-a-secure-random-string
NODE_ENV=development

# Server
PORT=8080

# Logging
LOG_LEVEL=info

# LLM Configuration (LMStudio local by default)
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://host.docker.internal:1234
LLM_MAIN_MODEL=hermes-3-llama-3.2-3b
LLM_JUDGE_MODEL=hermes-3-llama-3.2-3b
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_MS=30000

# For OpenAI/Google (when switching providers)
# LLM_API_KEY=your-api-key
