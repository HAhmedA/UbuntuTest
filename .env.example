# Database
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=postgres

# Session
SESSION_SECRET=change-this-to-a-secure-random-string
NODE_ENV=development

# Server
PORT=8080

# Logging
LOG_LEVEL=info

# LLM Configuration (LMStudio local by default)
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://host.docker.internal:1234
LLM_MAIN_MODEL=hermes-3-llama-3.2-3b
LLM_JUDGE_MODEL=qwen2.5-3b-instruct
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_MS=30000

# Context Management
# Default is 32k for production usage (e.g. GPT-4, Claude, Llama 3)
# For local testing with small models (e.g. LMStudio), set to 4096
LLM_CONTEXT_LIMIT=32768
LLM_RESPONSE_RESERVE=2000

# For OpenAI/Google (when switching providers)
# LLM_API_KEY=your-api-key
